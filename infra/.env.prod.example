# Copie para .env na instância (nunca commitar o .env real) e preencha com valores reais.
# Usado por: docker compose -f infra/docker-compose.prod.yml --env-file .env up -d

POSTGRES_DB=poupito
POSTGRES_USER=poupito
POSTGRES_PASSWORD=troque-por-uma-senha-forte

# openssl rand -base64 48
JWT_SECRET=troque-por-um-segredo-forte-e-unico

# domínio apontando (registro A) para o IP estático da instância
DOMAIN=poupito.exemplo.com
ACME_EMAIL=seu-email@exemplo.com

# imagens publicadas pelo CI (ghcr.io) — normalmente não precisa mudar
API_IMAGE=ghcr.io/jokerfoxyy/poupito-api:latest
WEB_IMAGE=ghcr.io/jokerfoxyy/poupito-web:latest

# usados só pelo script de backup (infra/scripts/backup.sh)
BACKUP_S3_BUCKET=poupito-backups
AWS_REGION=sa-east-1
